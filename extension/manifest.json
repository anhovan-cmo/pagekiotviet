{
  "manifest_version": 3,
  "name": "KiotViet to Facebook Auto Poster",
  "version": "1.2",
  "description": "Tự động lấy sản phẩm từ KiotViet và đăng lên Facebook cá nhân.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://id.kiotviet.vn/*",
    "https://public.api.kiotviet.vn/*",
    "https://www.facebook.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
